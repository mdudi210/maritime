ENVIRONMENT=production
DATABASE_URL=postgresql+psycopg://maritime:change-me@postgres:5432/maritime
JWT_SECRET_KEY=replace-with-a-long-random-production-secret
JWT_REFRESH_SECRET_KEY=replace-with-another-long-random-production-secret
CORS_ORIGINS=https://your-domain.example
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=replace-this-before-first-deploy
SEED_CREW_EMAIL=crew@example.com
SEED_CREW_USERNAME=crew
SEED_CREW_PASSWORD=replace-this-before-first-deploy
